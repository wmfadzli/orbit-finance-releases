<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Default (menu-bar app only). No App Group, no special capabilities, so it
      signs and runs with a FREE Apple ID.

      The app runs UNSANDBOXED so it can read ~/.claude/projects and ~/.codex.
      Under the sandbox, homeDirectoryForCurrentUser resolves to a container and
      the logs would be invisible.

      To ALSO ship the desktop widget, use App/TokenScopeWithWidget.entitlements
      instead (it adds the App Group the widget reads from).
    -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
